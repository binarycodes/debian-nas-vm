# msmtp configuration - generated by cloudyhome
defaults
auth           on
{% if config.health.alert.smtp_tls == "starttls" %}
tls            on
tls_starttls   on
{% elif config.health.alert.smtp_tls == "tls" %}
tls            on
tls_starttls   off
{% else %}
tls            off
tls_starttls   off
{% endif %}
syslog         LOG_MAIL

account        default
host           {{ config.health.alert.smtp_host }}
port           {{ config.health.alert.smtp_port }}
from           {{ alert_from }}
user           {{ smtp_user }}
password       {{ smtp_password }}
