# Garage configuration - generated by cloudyhome
metadata_dir = "{{ config.garage.metadata_dir }}"
data_dir = "{{ config.garage.data_dir }}"
replication_mode = "{{ config.garage.replication_mode }}"

[s3_api]
s3_region = "{{ config.garage.s3_region }}"
api_bind_addr = "{{ host_ip }}:{{ config.garage.s3_port }}"

[rpc_net]
rpc_bind_addr = "{{ host_ip }}:{{ config.garage.rpc_port }}"
rpc_secret = "{{ garage_rpc_secret }}"

[admin]
api_bind_addr = "{{ host_ip }}:{{ config.garage.admin_port }}"
admin_token = "{{ garage_admin_token }}"
