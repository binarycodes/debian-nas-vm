# Samba configuration - generated by cloudyhome
[global]
    workgroup = {{ config.samba.global_.workgroup }}
{% if config.samba.global_.server_string %}
    server string = {{ config.samba.global_.server_string }}
{% endif %}
    server min protocol = {{ config.samba.global_.min_protocol }}
    bind interfaces only = yes
    interfaces = {{ host_ip }}
    security = user
    map to guest = never
    passdb backend = tdbsam
    log file = /var/log/samba/log.%m
    max log size = 1000
{% for share in config.samba.shares if share.enabled %}

[{{ share.name }}]
    path = {{ share.path }}
    browsable = {{ "yes" if share.browsable else "no" }}
    read only = {{ "yes" if share.read_only else "no" }}
    guest ok = {{ "yes" if share.guest_ok else "no" }}
{% if samba_usernames[share.name] %}
    valid users = {{ samba_usernames[share.name] | join(" ") }}
{% endif %}
{% if share.write_list %}
    write list = {{ share.write_list | join(" ") }}
{% endif %}
{% if share.force_user %}
    force user = {{ share.force_user }}
{% endif %}
{% if share.force_group %}
    force group = {{ share.force_group }}
{% endif %}
{% if share.create_mask %}
    create mask = {{ share.create_mask }}
{% endif %}
{% if share.directory_mask %}
    directory mask = {{ share.directory_mask }}
{% endif %}
{% endfor %}
