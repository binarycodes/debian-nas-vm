#!/bin/bash
set -euo pipefail
# Service lifecycle script - generated by cloudyhome

systemctl daemon-reload

# Health monitoring (always)
systemctl enable smartd.service
systemctl enable zfs-zed.service
systemctl reload-or-restart smartd.service
systemctl reload-or-restart zfs-zed.service
systemctl start cloudyhome-zfs-scrub.timer
{% if config.nfs is not none %}

# NFS
systemctl reload-or-restart nfs-server.service
{% endif %}
{% if config.samba is not none %}

# Samba
systemctl reload-or-restart smbd.service
{% endif %}
{% if config.iscsi is not none %}

# iSCSI
systemctl restart target.service
{% endif %}
{% if config.garage is not none and config.garage.enabled %}

# Garage
systemctl start cloudyhome-garage.service
systemctl start cloudyhome-garage-bootstrap.service
{% endif %}
{% if config.ftp is not none and config.ftp.enabled %}

# FTP
systemctl start cloudyhome-ftp.service
{% endif %}
