# NFS exports - generated by cloudyhome
{% for export in config.nfs.exports if export.enabled %}
{% for client in export.clients %}
{% set client_idx = loop.index0 %}
{% set cidrs = nfs_cidrs[export.name][client_idx] %}
{% set client_opts = client.options if client.options else export.options %}
{% if client.identity_map.mode == "all_squash" %}
{% set id_opts = ["all_squash", "anonuid=" ~ client.identity_map.anon_uid, "anongid=" ~ client.identity_map.anon_gid] %}
{% elif client.identity_map.mode == "no_root_squash" %}
{% set id_opts = ["no_root_squash"] %}
{% else %}
{% set id_opts = ["root_squash"] %}
{% endif %}
{% set all_opts = client_opts + id_opts %}
{% for cidr in cidrs %}
{{ export.path }} {{ cidr }}({{ all_opts | join(",") }})
{% endfor %}
{% endfor %}
{% endfor %}
