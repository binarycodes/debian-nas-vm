#!/usr/bin/env python3
"""Validate NAS configuration and secrets."""
import logging
import sys

import yaml
from cloudyhome.models import NasConfig
from cloudyhome.secrets import secrets_context
from cloudyhome.validate import validate_all

SERVICES_PATH = "/var/lib/cloudyhome/nas/services.yml"

logging.basicConfig(format="%(message)s", level=logging.INFO)
log = logging.getLogger(__name__)


def main():
    try:
        with open(SERVICES_PATH) as f:
            raw = yaml.safe_load(f)
    except Exception as e:
        log.error("Failed to load %s: %s", SERVICES_PATH, e)
        sys.exit(1)

    try:
        config = NasConfig(**raw)
    except Exception as e:
        log.error("Schema validation failed: %s", e)
        sys.exit(1)

    try:
        with secrets_context() as secrets:
            errors = validate_all(config, secrets)
    except Exception as e:
        log.error("Secret decryption failed: %s", e)
        sys.exit(1)

    if errors:
        for err in errors:
            log.error("VALIDATION ERROR: %s", err)
        log.error("Validation failed with %d error(s)", len(errors))
        sys.exit(1)

    log.info("Configuration validated successfully")


if __name__ == "__main__":
    main()
