#!/usr/bin/env python3
"""Validate services.yml schema and static cross-field rules (no secrets required)."""
import logging
import sys

import yaml
from cloudyhome.constants import SERVICES_PATH
from cloudyhome.models import NasConfig
from cloudyhome.validate import validate_static

logging.basicConfig(format="%(message)s", level=logging.INFO)
log = logging.getLogger(__name__)


def main():
    try:
        with open(SERVICES_PATH) as f:
            raw = yaml.safe_load(f)
    except Exception as e:
        log.error("Failed to load %s: %s", SERVICES_PATH, e)
        sys.exit(1)

    try:
        config = NasConfig(**raw)
    except Exception as e:
        log.error("Schema validation failed: %s", e)
        sys.exit(1)

    errors = validate_static(config)

    if errors:
        for err in errors:
            log.error("VALIDATION ERROR: %s", err)
        log.error("Validation failed with %d error(s)", len(errors))
        sys.exit(1)

    log.info("Install-phase validation passed")


if __name__ == "__main__":
    main()
