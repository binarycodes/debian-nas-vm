#!/usr/bin/env python3
"""Apply NAS configuration: create datasets/zvols, provision users, start services."""
import fcntl
import logging
import os
import subprocess
import sys

import yaml
from cloudyhome.constants import (
    APPLY_LOCK, APPLY_SERVICES_SCRIPT, RUN_DIR, SERVICES_PATH,
    ZFS_DATASET_COMPRESSION, ZFS_DATASET_ATIME, ZFS_DATASET_DEDUP,
    ZFS_DATASET_SYNC, ZFS_DATASET_CASESENSITIVITY,
)
from cloudyhome.models import NasConfig
from cloudyhome.secrets import secrets_context, resolve_ref

logging.basicConfig(format="%(message)s", level=logging.INFO)
log = logging.getLogger(__name__)


def run_cmd(cmd, input_data=None, check=True):
    """Run a command, return CompletedProcess."""
    result = subprocess.run(cmd, capture_output=True, text=True, input=input_data)
    if check and result.returncode != 0:
        raise RuntimeError(f"Command failed: {' '.join(cmd)}\n{result.stderr}")
    return result


def zfs_get(prop, dataset):
    """Get a ZFS property value."""
    result = run_cmd(["zfs", "get", "-Hp", "-o", "value", prop, dataset])
    return result.stdout.strip()


def dataset_exists(dataset):
    """Check if a ZFS dataset exists."""
    result = run_cmd(["zfs", "list", "-H", dataset], check=False)
    return result.returncode == 0


def parse_size_bytes(s):
    """Parse a ZFS size string (e.g. '500G', '2T') to bytes."""
    units = {"K": 1024, "M": 1024**2, "G": 1024**3, "T": 1024**4}
    if s[-1] in units:
        return int(s[:-1]) * units[s[-1]]
    return int(s)


def create_datasets(config):
    """Create missing ZFS datasets and enforce quotas."""
    pool = config.storage.pool
    for key, ds in config.storage.datasets.items():
        full_name = f"{pool}/{key}"
        if not dataset_exists(full_name):
            log.info("Creating dataset %s with mountpoint %s", full_name, ds.path)
            run_cmd(["zfs", "create",
                     "-o", f"mountpoint={ds.path}",
                     "-o", f"compression={ZFS_DATASET_COMPRESSION}",
                     "-o", f"atime={ZFS_DATASET_ATIME}",
                     "-o", f"dedup={ZFS_DATASET_DEDUP}",
                     "-o", f"sync={ZFS_DATASET_SYNC}",
                     "-o", f"casesensitivity={ZFS_DATASET_CASESENSITIVITY}",
                     full_name])

        # Enforce quota
        current_quota_raw = zfs_get("quota", full_name)
        target_quota = ds.quota
        target_bytes = parse_size_bytes(target_quota)

        # current_quota_raw is in bytes or "none"/"0"
        if current_quota_raw in ("none", "0"):
            current_bytes = 0
        else:
            current_bytes = int(current_quota_raw)

        if current_bytes != target_bytes:
            # Check usage before applying any non-zero quota
            if target_bytes > 0:
                used_raw = zfs_get("used", full_name)
                used_bytes = int(used_raw)
                if used_bytes >= target_bytes:
                    raise RuntimeError(
                        f"Cannot set quota on {full_name}: "
                        f"usage {used_bytes} >= target quota {target_bytes}"
                    )
            log.info("Setting quota %s on %s", target_quota, full_name)
            run_cmd(["zfs", "set", f"quota={target_quota}", full_name])


def create_zvols(config):
    """Create missing iSCSI zvols."""
    if not config.iscsi:
        return
    for target in config.iscsi.targets:
        for lun in target.luns:
            full_path = f"{config.iscsi.dataset.lstrip('/')}/{lun.path}"
            if not dataset_exists(full_path):
                log.info("Creating zvol %s with size %s", full_path, lun.size)
                run_cmd(["zfs", "create", "-V", lun.size, full_path])
            else:
                log.info("zvol %s already exists, skipping", full_path)


def provision_samba_users(config, secrets):
    """Create OS users and provision tdbsam for Samba."""
    if not config.samba:
        return

    samba_users = resolve_ref(secrets, "samba/users")
    for username, user_data in samba_users.items():
        # Create OS user if not exists
        result = run_cmd(["id", username], check=False)
        if result.returncode != 0:
            log.info("Creating OS user %s", username)
            run_cmd(["useradd", "--no-create-home", "--shell", "/usr/sbin/nologin", username])

        # Check if user exists in tdbsam
        result = run_cmd(["pdbedit", "-L", "-u", username], check=False)
        password = user_data["password"]
        if result.returncode != 0:
            # Add user
            log.info("Adding Samba user %s", username)
            run_cmd(["smbpasswd", "-a", "-s", username], input_data=f"{password}\n{password}\n")
        else:
            # Update password
            log.info("Updating Samba user %s", username)
            run_cmd(["smbpasswd", "-s", username], input_data=f"{password}\n{password}\n")


def main():
    os.makedirs(RUN_DIR, exist_ok=True)
    lock_fd = open(APPLY_LOCK, "w")
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        log.error("Another apply process is running")
        sys.exit(1)

    try:
        with open(SERVICES_PATH) as f:
            raw = yaml.safe_load(f)
        config = NasConfig(**raw)

        # Step 1: daemon-reload and enable stock services
        log.info("Running systemctl daemon-reload")
        run_cmd(["systemctl", "daemon-reload"])
        log.info("Enabling stock health monitoring services")
        run_cmd(["systemctl", "enable", "smartd.service"])
        run_cmd(["systemctl", "enable", "zfs-zed.service"])

        # Step 2: Create datasets and zvols
        log.info("Creating datasets and zvols")
        create_datasets(config)
        create_zvols(config)

        with secrets_context() as secrets:
            # Step 3-4: Samba users
            provision_samba_users(config, secrets)

        # Step 5: Run apply-services script
        log.info("Running nas-apply-services.sh")
        run_cmd([APPLY_SERVICES_SCRIPT])

        log.info("Apply completed successfully")

    except Exception as e:
        log.error("Apply failed: %s", e)
        sys.exit(1)
    finally:
        fcntl.flock(lock_fd, fcntl.LOCK_UN)
        lock_fd.close()


if __name__ == "__main__":
    main()
